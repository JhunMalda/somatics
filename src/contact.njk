---
title: Contact
description: Book a somatic movement or breathwork session with Somatics.ph.
page_id: contact
dir: ..
---

{% include "header.njk" %}

<main class="sub">
  <article>
    <div class="lower-mv">
      <h1>Contact</h1>
    </div>

    <section class="contact-section">
      <p class="section-label animate-bottom">Get in Touch</p>
      <h2 class="section-h2 animate-bottom">Let's start a<br><em>conversation</em></h2>
      <div class="contact-inner">
        <div class="contact-grid">
          <div class="contact-info animate-bottom">
            <h3>We'd love to hear from you.</h3>
            <p>Whether you have questions about a specific practice, want to book a session, or simply want to know if this work is right for you — reach out. We respond within 24 hours.</p>
            <div class="contact-detail">
              <div class="contact-detail-icon">
                <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <strong>Location</strong>
                <span>Quezon City, Metro Manila, Philippines</span>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail-icon">
                <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <strong>Email</strong>
                <span>hello@somatics.ph</span>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail-icon">
                <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.35 2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
              </div>
              <div>
                <strong>WhatsApp / Viber</strong>
                <span>+63 917 000 0000</span>
              </div>
            </div>
          </div>

          <form id="contact-form" class="animate-bottom">
            <div class="form-row">
              <div class="form-group">
                <label for="fname">First Name</label>
                <input type="text" id="fname" name="fname" placeholder="Ana" />
              </div>
              <div class="form-group">
                <label for="lname">Last Name</label>
                <input type="text" id="lname" name="lname" placeholder="Cruz" />
              </div>
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="you@email.com" />
            </div>
            <div class="form-group">
              <label for="service">I'm interested in</label>
              <select id="service" name="service">
                <option value="">Select a service…</option>
                <option>1-on-1 Somatic Session</option>
                <option>Breathwork Session</option>
                <option>Group Class</option>
                <option>Workshop or Retreat</option>
                <option>Online Program</option>
                <option>Just exploring</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" placeholder="Tell us a little about what brought you here…"></textarea>
            </div>
            <button type="submit" class="btn-submit">Send Message</button>
            <p id="form-success" class="form-success">Thank you — we'll be in touch soon ✓</p>
          </form>
        </div>
      </div>
    </section>
  </article>
</main>

{% include "footer.njk" %}
